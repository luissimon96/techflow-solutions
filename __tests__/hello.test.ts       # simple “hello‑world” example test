const assert = require('assert');

function hello(name) {
    if (!name) return 'Hello, World!';
    return `Hello, ${name}!`;
}

test('hello world with no name', () => {
    assert.strictEqual(hello(), 'Hello, World!');
});

test('hello world with a name', () => {
    assert.strictEqual(hello('Alice'), 'Hello, Alice!');
});

test('hello world with an empty string', () => {
    assert.strictEqual(hello(''), 'Hello, !');
});

test('hello world with a number', () => {
    assert.strictEqual(hello(123), 'Hello, 123!');
});