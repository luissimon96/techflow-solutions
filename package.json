{
  "name": "techflow-solutions",
  "version": "1.0.0",
  "description": "TechFlow Solutions - React frontend web application for software development services",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "cd frontend && npm run preview",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "clean": "npm run clean:frontend",
    "clean:frontend": "cd frontend && npm run clean 2>nul || echo \"Frontend clean completed\"",
    "test": "npm run test:frontend",
    "test:frontend": "cd frontend && npm test",
    "lint": "npm run lint:frontend",
    "lint:frontend": "cd frontend && npm run lint",
    "format": "npm run format:frontend",
    "format:frontend": "cd frontend && npm run format",
    "deploy:prepare": "npm run build && echo 'Build completo - pronto para deploy'",
    "health:check": "curl -f http://localhost:5173/",
    "logs:frontend": "cd frontend && npm run logs"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "techflow",
    "fullstack",
    "react",
    "typescript",
    "nodejs",
    "express",
    "whatsapp-integration"
  ],
  "author": "TechFlow Solutions",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/luissimon96/techflow-solutions.git"
  },
  "dependencies": {
    "playwright": "^1.56.1"
  }
}